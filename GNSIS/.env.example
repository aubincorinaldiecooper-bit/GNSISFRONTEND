# ---- GNSIS frontend configuration (public values only) ----
# Everything here ships to the browser bundle. NEVER put a server secret in a
# VITE_ var: GNSIS_API_KEY, OPENROUTER_API_KEY, BETTER_AUTH_SECRET,
# GNSIS_VIRTUAL_KEY_PEPPER, GNSIS_AUTH_INTERNAL_SECRET, the GitHub client secret,
# and any Stripe secret / webhook secret belong only on the backend / auth service.

# Base URL of the GNSIS FastAPI backend (no trailing slash), e.g.
# https://gnsisbackend-production.up.railway.app
VITE_API_BASE_URL=

# Base URL of the Better Auth service (no trailing slash), e.g.
# https://gnsis-auth-production.up.railway.app
VITE_AUTH_URL=

# GitHub App slug — used only to build the public "Install the app" link.
VITE_GITHUB_APP_SLUG=

# Show the Integration Lab (/integration-test) in the app nav. Default: true.
VITE_ENABLE_INTEGRATION_LAB=true

# Model id pre-filled in the gateway smoke test. Must be a model your backend's
# OpenRouter key can call, e.g. anthropic/claude-opus-4.8
VITE_SMOKE_TEST_MODEL=

# DEPRECATED — old name for VITE_API_BASE_URL. Only used as a fallback when
# VITE_API_BASE_URL is unset. Prefer VITE_API_BASE_URL for new deployments.
# VITE_API_URL=
