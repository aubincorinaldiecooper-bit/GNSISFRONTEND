# GNSIS auth service (Better Auth) — copy to .env for local dev.
# Placeholders only — never commit real credentials.

NODE_ENV=development

# Postgres connection for Better Auth's own tables (user/account/session/jwks).
# Can be the same Postgres instance as the backend, a different database.
AUTH_DATABASE_URL=postgresql://user:pass@host:5432/gnsis_auth

# A long, random secret used to sign session tokens. Generate with e.g.
# `openssl rand -base64 32`.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# This service's own public URL (used as the JWT issuer and OAuth callback base).
BETTER_AUTH_URL=http://localhost:3001

# GitHub OAuth App credentials (identity/login only — separate from the
# GitHub App used for repository access, which lives on the backend).
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# The deployed frontend origin — the only trusted origin for sessions/CORS.
GNSIS_FRONTEND_URL=http://localhost:5173

# Audience claim on minted JWTs; must match BETTER_AUTH_AUDIENCE on the backend.
GNSIS_API_AUDIENCE=gnsis-api

# Shared secret for the backend's server-to-server installation-verification
# call. Generate with e.g. `openssl rand -base64 32`. Must match
# GNSIS_AUTH_INTERNAL_SECRET on the backend.
GNSIS_AUTH_INTERNAL_SECRET=replace-with-a-long-random-shared-secret

# PORT=3001
